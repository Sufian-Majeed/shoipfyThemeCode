{% doc %}
  @prompt
    create a section that show random number of visitor on this website currently watching the website
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-visitor-counter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-visitor-counter__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
  }

  .ai-visitor-counter__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-visitor-counter__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
  }

  .ai-visitor-counter__number-{{ ai_gen_id }} {
    color: {{ block.settings.number_color }};
    font-weight: {{ block.settings.number_weight }};
    font-size: {{ block.settings.number_size }}px;
  }

  .ai-visitor-counter__pulse-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.pulse_size }}px;
    height: {{ block.settings.pulse_size }}px;
    background-color: {{ block.settings.pulse_color }};
    border-radius: 50%;
    margin-right: 8px;
    position: relative;
  }

  {% if block.settings.show_pulse_animation %}
    .ai-visitor-counter__pulse-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      height: 100%;
      background-color: {{ block.settings.pulse_color }};
      border-radius: 50%;
      animation: ai-visitor-pulse-{{ ai_gen_id }} 2s ease-out infinite;
    }

    @keyframes ai-visitor-pulse-{{ ai_gen_id }} {
      0% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(2);
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-visitor-counter-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-visitor-counter__content-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{% endstyle %}

<visitor-counter-{{ ai_gen_id }}
  class="ai-visitor-counter-{{ ai_gen_id }}"
  data-min="{{ block.settings.min_visitors }}"
  data-max="{{ block.settings.max_visitors }}"
  data-update-interval="{{ block.settings.update_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-visitor-counter__content-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <svg
        class="ai-visitor-counter__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
    {% endif %}

    <div class="ai-visitor-counter__text-{{ ai_gen_id }}">
      {% if block.settings.show_pulse %}
        <span class="ai-visitor-counter__pulse-{{ ai_gen_id }}"></span>
      {% endif %}
      <span class="ai-visitor-counter__number-{{ ai_gen_id }}" data-visitor-count>{{ block.settings.min_visitors }}</span>
      {{ block.settings.text }}
    </div>
  </div>
</visitor-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class VisitorCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.minVisitors = parseInt(this.dataset.min) || 10;
        this.maxVisitors = parseInt(this.dataset.max) || 100;
        this.updateInterval = parseInt(this.dataset.updateInterval) * 1000 || 5000;
        this.currentCount = this.minVisitors;
        this.countElement = null;
        this.intervalId = null;
      }

      connectedCallback() {
        this.countElement = this.querySelector('[data-visitor-count]');
        this.initializeCount();
        this.startUpdating();
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }

      initializeCount() {
        this.currentCount = this.getRandomCount();
        this.updateDisplay();
      }

      getRandomCount() {
        return Math.floor(Math.random() * (this.maxVisitors - this.minVisitors + 1)) + this.minVisitors;
      }

      updateDisplay() {
        if (this.countElement) {
          this.countElement.textContent = this.currentCount;
        }
      }

      startUpdating() {
        this.intervalId = setInterval(() => {
          const change = Math.random() < 0.5 ? -1 : 1;
          const newCount = this.currentCount + change;

          if (newCount >= this.minVisitors && newCount <= this.maxVisitors) {
            this.currentCount = newCount;
          } else {
            this.currentCount = this.getRandomCount();
          }

          this.updateDisplay();
        }, this.updateInterval);
      }
    }

    customElements.define('visitor-counter-{{ ai_gen_id }}', VisitorCounter{{ ai_gen_id }});
  })();
</script>

{% schema %}
