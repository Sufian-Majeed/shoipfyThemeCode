{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .cod-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 10px 14px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    margin-block: 4px;
  }

  .cod-badge__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: #166534;
  }

  .cod-badge__item-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #16a34a;
  }
{% endstyle %}

<div class="cod-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="cod-badge__item-{{ ai_gen_id }}">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="5" width="20" height="14" rx="2"/>
      <line x1="2" y1="10" x2="22" y2="10"/>
    </svg>
    Cash on Delivery
  </div>
  <div class="cod-badge__item-{{ ai_gen_id }}">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12l5 5L20 7"/>
    </svg>
    Easy Returns
  </div>
  <div class="cod-badge__item-{{ ai_gen_id }}">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
      <path d="M16 3v4M8 3v4M12 12v3M12 15h.01"/>
    </svg>
    Secure Checkout
  </div>
</div>

{% schema %}
{
  "name": "COD Badge",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "COD Badge"
    }
  ]
}
{% endschema %}
