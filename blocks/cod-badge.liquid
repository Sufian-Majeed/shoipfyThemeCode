{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .cod-badge-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 6px;
    margin-bottom: 0;
  }

  .cod-badge__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px 8px;
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .cod-badge__icon-{{ ai_gen_id }} {
    width: 28px;
    height: 28px;
    background: #f0fdf4;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cod-badge__icon-{{ ai_gen_id }} svg {
    width: 15px;
    height: 15px;
    color: #16a34a;
  }

  .cod-badge__label-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 600;
    color: #111;
    line-height: 1.3;
  }

  .cod-badge__sub-{{ ai_gen_id }} {
    font-size: 10px;
    color: #6b7280;
    line-height: 1.2;
  }

  @media (max-width: 480px) {
    .cod-badge__label-{{ ai_gen_id }} {
      font-size: 10px;
    }
    .cod-badge__sub-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<div class="cod-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

  <div class="cod-badge__item-{{ ai_gen_id }}">
    <div class="cod-badge__icon-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <line x1="2" y1="10" x2="22" y2="10"/>
      </svg>
    </div>
    <span class="cod-badge__label-{{ ai_gen_id }}">Cash on Delivery</span>
    <span class="cod-badge__sub-{{ ai_gen_id }}">Pay at doorstep</span>
  </div>

  <div class="cod-badge__item-{{ ai_gen_id }}">
    <div class="cod-badge__icon-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
      </svg>
    </div>
    <span class="cod-badge__label-{{ ai_gen_id }}">Easy Returns</span>
    <span class="cod-badge__sub-{{ ai_gen_id }}">Hassle free</span>
  </div>

  <div class="cod-badge__item-{{ ai_gen_id }}">
    <div class="cod-badge__icon-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <span class="cod-badge__label-{{ ai_gen_id }}">Secure Checkout</span>
    <span class="cod-badge__sub-{{ ai_gen_id }}">100% protected</span>
  </div>

</div>

{% schema %}
{
  "name": "COD Badge",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "COD Badge"
    }
  ]
}
{% endschema %}
