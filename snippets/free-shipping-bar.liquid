{%- liquid
  assign threshold = 250000
  assign cart_total = cart.total_price
  assign remaining = threshold | minus: cart_total
  assign progress = cart_total | times: 100 | divided_by: threshold
  if progress > 100
    assign progress = 100
  endif
  assign remaining_formatted = remaining | money | remove: '.00'
-%}

<div class="free-shipping-bar">
  {% if cart_total >= threshold %}
    <div class="free-shipping-bar__message free-shipping-bar__message--achieved">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12l5 5L20 7"/>
      </svg>
      You've unlocked <strong>Free Shipping!</strong>
    </div>
  {% else %}
    <div class="free-shipping-bar__message">
      Add <strong>{{ remaining_formatted }}</strong> more for <strong>Free Shipping</strong>
    </div>
  {% endif %}
  <div class="free-shipping-bar__track">
    <div class="free-shipping-bar__fill" style="width: {{ progress }}%;"></div>
  </div>
</div>

<style>
  .free-shipping-bar {
    padding: 12px 16px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    margin-bottom: 16px;
  }

  .free-shipping-bar__message {
    font-size: 13px;
    color: #374151;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .free-shipping-bar__message--achieved {
    color: #16a34a;
    font-weight: 500;
  }

  .free-shipping-bar__track {
    height: 6px;
    background: #e5e7eb;
    border-radius: 100px;
    overflow: hidden;
  }

  .free-shipping-bar__fill {
    height: 100%;
    background: #16a34a;
    border-radius: 100px;
    transition: width 0.4s ease;
  }
</style>
